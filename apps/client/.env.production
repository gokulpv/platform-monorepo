# Local static assets; production uses R2 (see deploy.yml default + Cloudflare Pages env).
PUBLIC_IMAGE_BASE_URL=https://pub-242354276e8d4346a4b0ef9928457f19.r2.dev/
# Used when the hostname has no tenant subdomain (e.g. plain localhost). Value may be tenant.subdomain or tenant.id (e.g. koi or t_koi).
TENANT_FALLBACK=t_koi
# Hono worker origin (no trailing slash). Used by `apiFetch` and `handleFetch`.
# Production: https://worker.gokulsreenilayam.workers.dev (also default in deploy.yml; set on Cloudflare Pages).
WORKER_BASE_PATH=https://worker.gokulsreenilayam.workers.dev
